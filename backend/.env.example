# =========================================================================
# Backend (.env) — copie para .env e ajuste os valores.
# NUNCA versione o arquivo .env real (contém segredos).
# =========================================================================

# Django
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Modo dev: rode com SQLite sem precisar de MySQL (útil para testes locais).
USE_SQLITE=0

# Banco de dados MySQL (deve bater com o serviço "db" do docker-compose)
MYSQL_DATABASE=todo
MYSQL_USER=todo
MYSQL_PASSWORD=todo
MYSQL_HOST=db
MYSQL_PORT=3306

# CORS — origens do frontend (Expo Web / dispositivo)
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Superusuário criado pelo comando seed_demo
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin12345

# E-mail (dev usa console: o token de reset aparece no log do backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@todo.local
PASSWORD_RESET_URL=http://localhost:8081/reset-password

# Entrypoint: se =1, roda o seed_demo automaticamente na subida do container
RUN_SEED=1
# Se =1, usa runserver (dev). Se =0, usa gunicorn (prod).
DJANGO_DEV=1

# --- Segurança / JWT (opcionais; valores abaixo são os defaults) ---
# Chave de assinatura dedicada dos JWT (default = SECRET_KEY)
# JWT_SIGNING_KEY=
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
PASSWORD_RESET_TIMEOUT=3600      # segundos de validade do token de reset
# Limites de rate limiting (formato do DRF, ex.: 10/min, 1000/day)
THROTTLE_ANON=60/min
THROTTLE_USER=1000/day
THROTTLE_LOGIN=10/min
THROTTLE_PASSWORD_RESET=5/min
# Em produção (DEBUG=0) o redirect p/ HTTPS é ligado; desative se necessário:
# SECURE_SSL_REDIRECT=1
