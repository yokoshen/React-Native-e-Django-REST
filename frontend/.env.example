# =========================================================================
# Frontend (Expo) — copie para .env e ajuste.
# Variáveis EXPO_PUBLIC_* ficam disponíveis no app em process.env.
# =========================================================================

# URL base da API Django.
# - Expo Web / emulador Android (localhost do host): http://localhost:8000
# - Dispositivo físico via Expo Go: use o IP da sua máquina na LAN,
#   ex.: http://192.168.0.10:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
