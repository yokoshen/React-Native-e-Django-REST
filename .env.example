# =========================================================================
# Variáveis do docker-compose (raiz). Copie para .env:  cp .env.example .env
# O docker compose carrega este arquivo automaticamente.
# =========================================================================

# --- Django ---
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- MySQL (serviço db) ---
MYSQL_DATABASE=todo
MYSQL_USER=todo
MYSQL_PASSWORD=todo
MYSQL_ROOT_PASSWORD=rootpass
# Porta no host para acessar o MySQL de fora (o backend usa a rede interna).
# Mude se a 3307 estiver ocupada.
MYSQL_HOST_PORT=3307

# --- CORS (origens do frontend) ---
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# --- Superusuário criado pelo seed ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin12345

# --- Comportamento do backend na subida ---
RUN_SEED=1      # 1 = roda seed_demo (admin + alice + bob) automaticamente
DJANGO_DEV=1    # 1 = runserver (dev) | 0 = gunicorn (prod)

# --- Frontend (Expo) ---
EXPO_PUBLIC_API_URL=http://localhost:8000
